# WaveForge USB device access rules — allows non-root access to FX2-based instruments
# Install: sudo cp 99-waveforge.rules /etc/udev/rules.d/ && sudo udevadm control --reload-rules && sudo udevadm trigger

# Hantek 6022BE (DSO) / 6022BL (Logic Analyzer)
SUBSYSTEM=="usb", ATTR{idVendor}=="0925", MODE="0666", GROUP="plugdev"

# Cypress FX2 bare chip (generic clones before firmware upload)
SUBSYSTEM=="usb", ATTR{idVendor}=="04b4", MODE="0666", GROUP="plugdev"

# fx2lafw sigrok VID (after firmware renumeration)
SUBSYSTEM=="usb", ATTR{idVendor}=="1d50", MODE="0666", GROUP="plugdev"
